# =============================================================================
# Library Management System — .gitignore
# =============================================================================

# Local environment config — NEVER commit these files


# PHP error logs & temporary files
*.log
error_log
*.cache
.env*
*.tmp
*.swp
testsprite_execution.log

# Test automation temporary files
tests/automation/tmp/
tests/automation/**/*.log

# Uploaded files / user content

assets/images/covers/book cover/
# IDE & editor
.vscode/
.idea/
*.suo
*.user

# OS noise
Thumbs.db
.DS_Store
Desktop.ini

# Composer (not used in this project yet, but precautionary)
vendor/
composer.lock
